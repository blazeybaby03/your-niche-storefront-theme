{% comment %}
  Niche Aura — snippets/seo-structured-data.liquid
  Outputs JSON-LD structured data for the store.
  Include in layout/theme.liquid before </head>:
    {%- render 'seo-structured-data' -%}
{% endcomment %}

{%- liquid
  assign store_name = shop.name | default: 'YOURNICHE'
  assign store_url  = shop.url
-%}

{% if template.name == 'index' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "{{ store_url }}/#organization",
      "name": "{{ store_name | escape }}",
      "url": "{{ store_url }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ shop.metafields.global.og_image | default: '' }}"
      },
      "sameAs": [
        "{{ settings.social_instagram_url }}",
        "{{ settings.social_tiktok_url }}",
        "{{ settings.social_pinterest_url }}",
        "{{ settings.social_facebook_url }}"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "{{ store_url }}/#website",
      "url": "{{ store_url }}",
      "name": "{{ store_name | escape }}",
      "publisher": {
        "@id": "{{ store_url }}/#organization"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{ store_url }}/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
  ]
}
</script>
{% endif %}

{% if template.name == 'product' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.title | escape }}",
  "description": "{{ product.description | strip_html | strip_newlines | truncate: 300 | escape }}",
  "url": "{{ shop.url }}{{ product.url }}",
  "image": [
    {%- for image in product.images limit: 3 -%}
      "{{ image | image_url: width: 1200 }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "brand": {
    "@type": "Brand",
    "name": "{{ product.vendor | escape | default: store_name }}"
  },
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "price": "{{ product.price | money_without_currency | remove: ',' }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "seller": {
      "@type": "Organization",
      "name": "{{ store_name | escape }}"
    }
  }
}
</script>
{% endif %}
