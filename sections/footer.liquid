{% comment %}
  Niche Aura — sections/footer.liquid
  Scheme 02 (Inverse): Deep Navy bg · Ice White text · Electric Teal accents
  Fonts: Montserrat 900 (wordmark) · Cormorant Garamond 300i (body) · JetBrains Mono 300i (labels)
{% endcomment %}

<style>
  /* ─── Footer wrapper ─────────────────────────────────────────── */
  #na-footer {
    background: var(--na-navy, #002D72);
    border-top: 1px solid var(--na-navy-800, #0C3E8A);
    color: var(--na-ice, #EEF4FB);
    font-family: 'Cormorant Garamond', serif;
  }

  /* ─── Main footer grid ───────────────────────────────────────── */
  .na-footer__main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 64px 24px 48px;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
  }

  /* ─── Brand column ───────────────────────────────────────────── */
  .na-footer__brand-wordmark {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 20px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--na-ice, #EEF4FB);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 16px;
    transition: color 0.2s ease;
  }

  .na-footer__brand-wordmark:hover {
    color: var(--na-teal, #09CDCD);
  }

  .na-footer__brand-tagline {
    font-size: 15px;
    font-weight: 300;
    font-style: italic;
    color: var(--na-sea-glass, #A0E5D9);
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 240px;
  }

  /* Social icons */
  .na-footer__social {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .na-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(238, 244, 251, 0.2);
    color: var(--na-ice, #EEF4FB);
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .na-footer__social-link:hover {
    border-color: var(--na-teal, #09CDCD);
    color: var(--na-teal, #09CDCD);
    background: rgba(9, 205, 205, 0.08);
  }

  .na-footer__social-link svg {
    width: 15px;
    height: 15px;
    fill: currentColor;
  }

  /* ─── Link columns ───────────────────────────────────────────── */
  .na-footer__col-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-style: italic;
    font-weight: 300;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--na-teal, #09CDCD);
    margin-bottom: 20px;
    display: block;
  }

  .na-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .na-footer__link {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    font-weight: 300;
    color: rgba(238, 244, 251, 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
    line-height: 1.3;
  }

  .na-footer__link:hover {
    color: var(--na-ice, #EEF4FB);
  }

  /* ─── Newsletter strip ───────────────────────────────────────── */
  .na-footer__newsletter {
    background: var(--na-navy-800, #0C3E8A);
    border-top: 1px solid rgba(9, 205, 205, 0.15);
    border-bottom: 1px solid rgba(9, 205, 205, 0.15);
  }

  .na-footer__newsletter-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 24px;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .na-footer__newsletter-copy {
    flex: 1;
  }

  .na-footer__newsletter-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-style: italic;
    font-weight: 300;
    letter-spacing: 1.5px;
    color: var(--na-teal, #09CDCD);
    margin-bottom: 6px;
    display: block;
  }

  .na-footer__newsletter-heading {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 18px;
    letter-spacing: -0.3px;
    color: var(--na-ice, #EEF4FB);
  }

  .na-footer__newsletter-form {
    display: flex;
    gap: 0;
    flex: 1;
    max-width: 420px;
  }

  .na-footer__newsletter-input {
    flex: 1;
    background: rgba(238, 244, 251, 0.06);
    border: 1px solid rgba(238, 244, 251, 0.15);
    border-right: none;
    border-radius: 40px 0 0 40px;
    padding: 11px 20px;
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    font-style: italic;
    font-weight: 300;
    color: var(--na-ice, #EEF4FB);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .na-footer__newsletter-input::placeholder {
    color: rgba(238, 244, 251, 0.35);
  }

  .na-footer__newsletter-input:focus {
    border-color: var(--na-teal, #09CDCD);
  }

  .na-footer__newsletter-btn {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    background: var(--na-teal, #09CDCD);
    color: var(--na-navy, #002D72);
    border: none;
    border-radius: 0 40px 40px 0;
    padding: 11px 22px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease;
  }

  .na-footer__newsletter-btn:hover {
    background: var(--na-sea-glass, #A0E5D9);
  }

  /* ─── Bottom bar ─────────────────────────────────────────────── */
  .na-footer__bottom {
    max-width: 1280px;
    margin: 0 auto;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .na-footer__copyright {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-style: italic;
    font-weight: 300;
    color: rgba(238, 244, 251, 0.3);
    letter-spacing: 0.5px;
  }

  .na-footer__legal-links {
    display: flex;
    gap: 20px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .na-footer__legal-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-style: italic;
    font-weight: 300;
    color: rgba(238, 244, 251, 0.3);
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: color 0.2s ease;
  }

  .na-footer__legal-link:hover {
    color: var(--na-ice, #EEF4FB);
  }

  /* ─── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .na-footer__main {
      grid-template-columns: 1fr 1fr;
      gap: 40px 32px;
    }

    .na-footer__newsletter-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }

    .na-footer__newsletter-form {
      max-width: 100%;
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .na-footer__main {
      grid-template-columns: 1fr;
      padding: 48px 16px 40px;
      gap: 32px;
    }

    .na-footer__newsletter-inner {
      padding: 28px 16px;
    }

    .na-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      padding: 16px;
      gap: 12px;
    }

    .na-footer__legal-links {
      flex-wrap: wrap;
      gap: 12px 20px;
    }
  }
</style>

{%- liquid
  assign shop_menu    = section.settings.footer_menu   | default: 'footer'
  assign help_menu    = section.settings.help_menu     | default: 'footer-help'
  assign policy_menu  = section.settings.policy_menu   | default: 'footer-legal'
  assign show_newsletter = section.settings.show_newsletter
  assign tagline      = section.settings.tagline
  assign wordmark     = section.settings.wordmark | default: shop.name | upcase
  assign current_year = 'now' | date: '%Y'
-%}

<footer id="na-footer" role="contentinfo">

  {%- comment %} ── Newsletter strip ── {%- endcomment %}
  {%- if show_newsletter -%}
    <div class="na-footer__newsletter">
      <div class="na-footer__newsletter-inner">
        <div class="na-footer__newsletter-copy">
          <span class="na-footer__newsletter-eyebrow">// stay in the loop</span>
          <p class="na-footer__newsletter-heading">{{ section.settings.newsletter_heading | default: 'New arrivals. Exclusive offers.' }}</p>
        </div>
        {%- form 'customer', id: 'na-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="na-footer__newsletter-form">
            <input
              type="email"
              name="contact[email]"
              class="na-footer__newsletter-input"
              placeholder="{{ section.settings.newsletter_placeholder | default: 'your@email.com' }}"
              aria-label="Email address for newsletter"
              autocomplete="email"
              required
            >
            <button type="submit" class="na-footer__newsletter-btn">
              {{ section.settings.newsletter_cta | default: 'Subscribe' }}
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment %} ── Main grid ── {%- endcomment %}
  <div class="na-footer__main">

    {%- comment %} Brand column {%- endcomment %}
    <div class="na-footer__brand">
      <a href="{{ routes.root_url }}" class="na-footer__brand-wordmark" aria-label="{{ shop.name }} — home">
        {{ wordmark }}
      </a>
      {%- if tagline != blank -%}
        <p class="na-footer__brand-tagline">{{ tagline }}</p>
      {%- endif -%}

      {%- comment %} Social links {%- endcomment %}
      <div class="na-footer__social">
        {%- if section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" class="na-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_tiktok != blank -%}
          <a href="{{ section.settings.social_tiktok }}" class="na-footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_pinterest != blank -%}
          <a href="{{ section.settings.social_pinterest }}" class="na-footer__social-link" aria-label="Pinterest" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0c-6.627 0-12 5.372-12 12 0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_facebook != blank -%}
          <a href="{{ section.settings.social_facebook }}" class="na-footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment %} Shop links {%- endcomment %}
    {%- if linklists[shop_menu].links.size > 0 -%}
      <div>
        <span class="na-footer__col-label">// shop</span>
        <ul class="na-footer__links">
          {%- for link in linklists[shop_menu].links -%}
            <li><a href="{{ link.url }}" class="na-footer__link">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- comment %} Help links {%- endcomment %}
    {%- if linklists[help_menu].links.size > 0 -%}
      <div>
        <span class="na-footer__col-label">// help</span>
        <ul class="na-footer__links">
          {%- for link in linklists[help_menu].links -%}
            <li><a href="{{ link.url }}" class="na-footer__link">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- comment %} Legal / policy links {%- endcomment %}
    {%- if linklists[policy_menu].links.size > 0 -%}
      <div>
        <span class="na-footer__col-label">// legal</span>
        <ul class="na-footer__links">
          {%- for link in linklists[policy_menu].links -%}
            <li><a href="{{ link.url }}" class="na-footer__link">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

  </div>{%- comment %} /.na-footer__main {%- endcomment %}

  {%- comment %} ── Bottom bar ── {%- endcomment %}
  <div style="border-top: 1px solid rgba(238,244,251,0.06);">
    <div class="na-footer__bottom">
      <span class="na-footer__copyright">
        © {{ current_year }} {{ shop.name }}. All rights reserved.
      </span>
      {%- if shop.enabled_payment_types.size > 0 -%}
        <div style="display:flex; gap:6px; flex-wrap:wrap; align-items:center;">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'na-footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>

</footer>

<style>
  /* Payment icons auto-rendered by Shopify */
  .na-footer__payment-icon {
    height: 22px;
    width: auto;
    opacity: 0.4;
    filter: grayscale(1) brightness(3);
  }
</style>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "na-footer-section",
  "settings": [
    {
      "type": "text",
      "id": "wordmark",
      "label": "Wordmark text",
      "default": "YOURNICHE"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Curated products, made to last."
    },
    {
      "type": "header",
      "content": "Navigation menus"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Shop links menu",
      "default": "footer",
      "info": "Create a menu called 'footer' in Navigation"
    },
    {
      "type": "link_list",
      "id": "help_menu",
      "label": "Help links menu",
      "info": "Create a menu called 'footer-help' in Navigation"
    },
    {
      "type": "link_list",
      "id": "policy_menu",
      "label": "Legal / policy links menu",
      "info": "Create a menu called 'footer-legal' in Navigation"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "New arrivals. Exclusive offers."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "newsletter_cta",
      "label": "Subscribe button label",
      "default": "Subscribe"
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    }
  ],
  "blocks": [],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
