{% comment %}
  Niche Aura — sections/related-products.liquid
  Scheme 01 (Primary): Ice White bg · Deep Navy text · Electric Teal accents
  Uses Shopify's product_recommendations endpoint (AI-powered).
  Falls back to same-collection products if no recommendations available.
{% endcomment %}

<style>
  .na-related {
    background: var(--na-ice, #EEF4FB);
    padding: 64px 24px 80px;
    border-top: 1px solid var(--na-b100, #D4E6F8);
  }

  .na-related__inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ─── Header ─────────────────────────────────────────────────── */
  .na-related__eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-style: italic;
    font-weight: 300;
    letter-spacing: 2px;
    color: var(--na-teal, #09CDCD);
    margin-bottom: 8px;
    display: block;
  }

  .na-related__heading {
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    font-size: 26px;
    letter-spacing: -0.5px;
    color: var(--na-navy, #002D72);
    margin-bottom: 40px;
  }

  /* ─── Product grid ───────────────────────────────────────────── */
  .na-related__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  /* ─── Product card ───────────────────────────────────────────── */
  .na-product-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .na-product-card__image-wrap {
    aspect-ratio: 1;
    border-radius: 12px;
    overflow: hidden;
    background: var(--na-b100, #D4E6F8);
    margin-bottom: 12px;
    position: relative;
  }

  .na-product-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .na-product-card:hover .na-product-card__image-wrap img {
    transform: scale(1.04);
  }

  .na-product-card__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    font-style: italic;
    font-weight: 300;
    letter-spacing: 1px;
    padding: 3px 9px;
    border-radius: 40px;
  }

  .na-product-card__badge--sale {
    background: var(--na-violet, #81459E);
    color: var(--na-ice, #EEF4FB);
  }

  .na-product-card__badge--new {
    background: var(--na-teal, #09CDCD);
    color: var(--na-navy, #002D72);
  }

  .na-product-card__vendor {
    font-family: 'JetBrains Mono', monospace;
    font-size: 8px;
    font-style: italic;
    font-weight: 300;
    letter-spacing: 1px;
    color: rgba(0, 45, 114, 0.4);
    margin-bottom: 4px;
    display: block;
  }

  .na-product-card__title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: -0.2px;
    color: var(--na-navy, #002D72);
    margin-bottom: 6px;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .na-product-card:hover .na-product-card__title {
    color: var(--na-teal, #09CDCD);
  }

  .na-product-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .na-product-card__price {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: var(--na-navy, #002D72);
  }

  .na-product-card__compare {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-weight: 300;
    color: rgba(0, 45, 114, 0.35);
    text-decoration: line-through;
  }

  /* Hidden gracefully when no recommendations */
  .na-related[aria-hidden="true"] {
    display: none;
  }

  /* ─── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .na-related__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  @media (max-width: 480px) {
    .na-related {
      padding: 48px 16px 60px;
    }

    .na-related__grid {
      gap: 12px;
    }
  }
</style>

{%- liquid
  assign rec_limit = section.settings.products_to_show | default: 4
  assign heading   = section.settings.heading | default: 'You May Also Like'
  assign eyebrow   = section.settings.eyebrow | default: 'recommended'
-%}

<section
  class="na-related"
  id="na-related-section"
  data-product-id="{{ product.id }}"
  data-limit="{{ rec_limit }}"
  aria-label="{{ heading }}"
>
  <div class="na-related__inner">
    <span class="na-related__eyebrow">// {{ eyebrow }}</span>
    <h2 class="na-related__heading">{{ heading }}</h2>

    <div class="na-related__grid" id="na-related-grid">
      {%- comment %}
        Populated client-side via the Shopify Product Recommendations API.
        Falls back to same-collection products via Liquid if JS is disabled.
      {%- endcomment %}

      {%- if collection -%}
        {%- for rec_product in collection.products limit: rec_limit -%}
          {%- unless rec_product.id == product.id -%}
            {%- render 'product-card', product: rec_product -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment %} Product card snippet — inline here for portability {%- endcomment %}
{%- capture product_card_html -%}
  {%- for rec_product in recommendations.products limit: rec_limit -%}
    <a href="{{ rec_product.url }}" class="na-product-card">
      <div class="na-product-card__image-wrap">
        {%- if rec_product.featured_image -%}
          <img
            src="{{ rec_product.featured_image | image_url: width: 600 }}"
            alt="{{ rec_product.featured_image.alt | escape }}"
            width="600"
            height="600"
            loading="lazy"
          >
        {%- endif -%}
        {%- if rec_product.compare_at_price > rec_product.price -%}
          <span class="na-product-card__badge na-product-card__badge--sale">// sale</span>
        {%- endif -%}
      </div>
      <span class="na-product-card__vendor">{{ rec_product.vendor }}</span>
      <p class="na-product-card__title">{{ rec_product.title }}</p>
      <div class="na-product-card__price-row">
        <span class="na-product-card__price">{{ rec_product.price | money }}</span>
        {%- if rec_product.compare_at_price > rec_product.price -%}
          <span class="na-product-card__compare">{{ rec_product.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
    </a>
  {%- endfor -%}
{%- endcapture -%}

<script>
  (function () {
    const section   = document.getElementById('na-related-section');
    const grid      = document.getElementById('na-related-grid');
    if (!section || !grid) return;

    const productId = section.dataset.productId;
    const limit     = section.dataset.limit || 4;
    const url       = `/recommendations/products.json?product_id=${productId}&limit=${limit}&intent=related`;

    fetch(url)
      .then(r => r.json())
      .then(({ products }) => {
        if (!products || products.length === 0) {
          section.setAttribute('aria-hidden', 'true');
          return;
        }

        const cards = products.map(p => {
          const img    = p.featured_image ? `<img src="${p.featured_image}" alt="${p.title}" width="600" height="600" loading="lazy">` : '';
          const sale   = p.compare_at_price > p.price ? `<span class="na-product-card__badge na-product-card__badge--sale">// sale</span>` : '';
          const cmpPrc = p.compare_at_price > p.price ? `<span class="na-product-card__compare">${formatMoney(p.compare_at_price)}</span>` : '';

          return `
            <a href="/products/${p.handle}" class="na-product-card">
              <div class="na-product-card__image-wrap">${img}${sale}</div>
              <span class="na-product-card__vendor">${p.vendor}</span>
              <p class="na-product-card__title">${p.title}</p>
              <div class="na-product-card__price-row">
                <span class="na-product-card__price">${formatMoney(p.price)}</span>${cmpPrc}
              </div>
            </a>`;
        });

        grid.innerHTML = cards.join('');
      })
      .catch(() => {
        // Silently keep the Liquid fallback content
      });

    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2);
    }
  })();
</script>

{% schema %}
{
  "name": "Related products",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "recommended"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
